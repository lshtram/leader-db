# Environment placeholders for leaders-db

# --- Database (prototype: SQLite, future: PostgreSQL) ---
# LEADERSDB_DB_URL=sqlite:///data/catalog/leaders_db.sqlite
# LEADERSDB_DB_URL=postgresql+psycopg://user:pass@localhost:5432/leaders_db

# --- LLM adapter (optional) ---
# Provider-agnostic. See src/leaders_db/llm/caller.py.
# LEADERSDB_LLM_PROVIDER=openai
# LEADERSDB_LLM_MODEL=gpt-4o-mini
# LEADERSDB_LLM_API_KEY=sk-replace-me
# LEADERSDB_LLM_BASE_URL=https://api.openai.com/v1
# LEADERSDB_LLM_TIMEOUT_S=60

# --- External dataset downloads (Stage 0 / Stage 2) ---
# V-Dem: free download, no key required
# LEADERSDB_VDEM_URL=
# World Bank WDI / WGI: free API, no key required
# Transparency International CPI: free download
# UCDP: free download
# Archigos / REIGN / Leader Survival: free academic datasets
