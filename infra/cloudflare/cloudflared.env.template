# Copy to infra/cloudflare/cloudflared.env after creating the tunnel in
# Cloudflare Zero Trust. Do not commit the copied file.

# Remotely-managed tunnel token from Cloudflare Zero Trust > Networks > Tunnels.
# Create the Access application and allowlist policy before adding the public
# hostname route, so viz.chopsworkshop.com is never briefly public.
TUNNEL_TOKEN=replace-with-cloudflare-tunnel-token
