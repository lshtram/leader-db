# Environment and secrets
.env
.env.*
!.env.example

# Local editor / agent state
.claude/
.accordo/
.opencode/
.vscode/
.idea/

# Python environments and packaging
.venv/
venv/
env/
ENV/
build/
dist/
*.egg-info/
*.egg
.eggs/
pip-wheel-metadata/

# Python caches and test artifacts
__pycache__/
*.py[cod]
.pytest_cache/
.ruff_cache/
.mypy_cache/
htmlcov/
.coverage
.coverage.*
coverage.xml
*.cover

# Logs and runtime scratch
logs/
*.log

# Scratch / working area
tmp/
.scratch/

# Local data lake — inputs and derived artifacts are not committed in v1.
# The folder skeletons and README files are committed; the data itself is not.
# Recursive globs (`/**/`) cover every per-source subfolder plus arbitrary
# nesting for archival layouts (e.g. `data/raw/<source>/<archive>/<file>.csv`).
data/raw/**/*.xlsx
data/raw/**/*.xls
data/raw/**/*.docx
data/raw/**/*.docx.lock
data/raw/**/*.csv
data/raw/**/*.csv.gz
data/raw/**/*.tsv
data/raw/**/*.zip
data/raw/**/*.dta
data/raw/**/*.sav
data/raw/**/*.parquet
data/raw/**/*.json
data/raw/**/*.pdf
data/raw/**/*.xml
data/raw/**/*.html
data/raw/**/*.htm
data/processed/**/*.csv
data/processed/**/*.parquet
data/processed/**/*.json
data/interim/**/*.csv
data/interim/**/*.parquet
data/outputs/**/*.csv
data/outputs/**/*.xlsx
data/outputs/**/*.md
data/outputs/**/*.json
data/outputs/**/*.html
# Recursive log + metadata artifacts. Per-source placeholders
# (.gitkeep, README.md) remain committed so the data-lake skeleton
# is reproducible from a clean checkout; the per-run artifacts inside
# data/logs/ and data/metadata/ are not.
data/logs/**
!data/logs/.gitkeep
data/metadata/**
!data/metadata/.gitkeep

# Research outputs are derived artifacts
research/**/*.csv
research/**/*.parquet
research/**/*.md
research/**/*.html
research/**/*.json

# Database files (SQLite catalog, DuckDB catalog)
*.db
*.sqlite
*.sqlite3
*.duckdb
data/catalog/*.duckdb
data/catalog/*.sqlite

# OS / editor temp files
.DS_Store
Thumbs.db
.~lock.*#
*.swp
*.swo
*~

# Botched `pip install pkg>=X.Y` — the shell interprets `>` as redirection
# and the `=X.Y` survives as a stray file at the project root.
=*

# Jupyter
.ipynb_checkpoints/

# Build / distribution
*.whl
